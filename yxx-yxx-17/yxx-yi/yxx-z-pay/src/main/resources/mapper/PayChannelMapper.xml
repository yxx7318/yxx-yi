<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yxx.pay.mapper.PayChannelMapper">

    <resultMap type="com.yxx.pay.core.domain.channel.PayChannelDO" id="PayChannelResult">
        <id property="channelId" column="channel_id"/>
        <result property="channelCode" column="channel_code"/>
        <result property="channelName" column="channel_name"/>
        <result property="channelConfig" column="channel_config" typeHandler="com.baomidou.mybatisplus.extension.handlers.Fastjson2TypeHandler"/>
        <result property="channelFeeRate" column="channel_fee_rate"/>
        <result property="status" column="status"/>
        <result property="createById" column="create_by_id"/>
        <result property="createByName" column="create_by_name"/>
        <result property="createTime" column="create_time"/>
        <result property="updateById" column="update_by_id"/>
        <result property="updateByName" column="update_by_name"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPayChannelVo">
        select channel_id, channel_code, channel_name, channel_config, channel_fee_rate, status,
               create_by_id, create_by_name, create_time, update_by_id, update_by_name, update_time, remark
        from pay_channel
    </sql>

    <select id="selectByChannelId" parameterType="Long" resultMap="PayChannelResult">
        <include refid="selectPayChannelVo"/>
        where channel_id = #{channelId}
    </select>

    <select id="selectByChannelCode" parameterType="String" resultMap="PayChannelResult">
        <include refid="selectPayChannelVo"/>
        where channel_code = #{channelCode}
    </select>

    <select id="selectList" resultMap="PayChannelResult">
        <include refid="selectPayChannelVo"/>
        order by channel_id asc
    </select>

    <select id="selectListByStatus" resultMap="PayChannelResult">
        <include refid="selectPayChannelVo"/>
        where status = #{status}
        order by channel_id asc
    </select>

    <update id="updateStatus">
        update pay_channel set status = #{status}, update_time = now() where channel_id = #{channelId}
    </update>

</mapper>
